# Supply-chain hardening: only install package versions that have been public
# for more than 7 days. A freshly-published compromised or broken release is
# usually yanked within a few days, so this cooldown avoids pulling one during
# `npm install` / `npm ci` (locally and in CI). It complements the Dependabot
# `cooldown` in .github/dependabot.yml, which applies the same delay to update
# PRs. npm does NOT read this setting from package.json — .npmrc is npm's config
# file and is committed so the policy applies to every clone and CI run.
# Exempt specific packages with: min-release-age-exclude[]=<name>
min-release-age=7
